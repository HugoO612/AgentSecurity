{
  "name": "agentsecurity",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:app": "vite",
    "dev:bridge": "node --watch --experimental-strip-types bridge/server.ts",
    "dev:full": "node scripts/dev-full.mjs",
    "bridge": "node --experimental-strip-types bridge/server.ts",
    "build:assets": "node scripts/build-release-assets.mjs",
    "validate:live": "node scripts/run-live-validation.mjs",
    "build": "tsc -p tsconfig.bridge.json && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run && npm run check:terms",
    "test:watch": "vitest",
    "check:terms": "node ./scripts/scan-banned-terms.mjs"
  },
  "dependencies": {
    "@xstate/react": "^6.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "xstate": "^5.30.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.1.12",
    "vitest": "^4.1.5"
  }
}
